# ==============================================================
# Analytics / Marketing IDs — คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# บน Netlify: Site settings → Environment variables → เพิ่มทีละตัว
# หมายเหตุ: เว็บเป็น static export ค่าจะถูกฝังตอน build
# แก้ค่าแล้วต้อง Deploy ใหม่ทุกครั้ง
# ==============================================================

# Google Tag Manager container ID (รูปแบบ GTM-XXXXXXX)
# สมัครที่ https://tagmanager.google.com — ใส่ค่าแล้ว GTM จะถูกโหลดอัตโนมัติ
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 Measurement ID (รูปแบบ G-XXXXXXXXXX)
# ไม่ได้ฝัง gtag.js ตรง ๆ — ค่านี้ถูก push เข้า dataLayer เป็นตัวแปร "ga_measurement_id"
# ให้สร้าง GA4 Configuration tag ใน GTM แล้วอ่านค่าจาก dataLayer variable นี้
NEXT_PUBLIC_GA_ID=

# Facebook Pixel ID (ตัวเลขล้วน) — จาก Meta Events Manager
# ยิง PageView ทุกหน้า + Lead เมื่อกรอกฟอร์ม/กดโทร/กด Line
NEXT_PUBLIC_FB_PIXEL_ID=

# LINE Tag ID — จาก LINE Official Account Manager → LINE Tag
NEXT_PUBLIC_LINE_TAG_ID=
